      o_Packet_Data   => w_Packet_Data
    );

  -- ==========================================================================
  -- Explicit ILA Instance Hookup (Streams data to your PC via USB)
  -- ==========================================================================
  ILA_Debugger : ila_0
    port map (
      clk        => i_Clk,
      probe0(0)  => w_Tx_Serial,
      probe1(0)  => w_Packet_Valid,
      probe2(0)  => w_Internal_Rst,
      probe3     => w_Packet_Data
    );

  -- ==========================================================================
  -- Hardware Pulse Stretcher Logic Block
  -- ==========================================================================
  p_Pulse_Stretcher : process (i_Clk)
  begin
    if rising_edge(i_Clk) then
      if w_Internal_Rst = '0' then
        r_Led_State <= '0';
        r_Led_Timer <= 0;
      else
        if w_Packet_Valid = '1' then
          r_Led_State <= '1';
          r_Led_Timer <= 0;
        elsif r_Led_State = '1' then
          if r_Led_Timer < c_LED_HOLD_CYCLES then
            r_Led_Timer <= r_Led_Timer + 1;
          else
            r_Led_State <= '0';
            r_Led_Timer <= 0;
          end if;
        end if;
      end if;
    end if;
  end process p_Pulse_Stretcher;

  o_Led_Valid  <= r_Led_State;
  o_Led_Header <= w_Header_Error;
  o_Led_Csum   <= w_Csum_Error;

end Structural;
