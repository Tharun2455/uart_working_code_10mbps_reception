-- Internal 10 Mbps UART Transmitter Block (Array Version)
  p_Internal_TX : process (i_Clk)
    variable v_Byte_Idx : integer range 0 to 9 := 0;
    variable v_Bit_Idx  : integer range 0 to 9 := 0;
  begin
    if rising_edge(i_Clk) then
      r_Trigger_d1 <= i_Tx_Trigger;
      
      if w_Internal_Rst = '1' then
        r_Tx_Active  <= '0';
        w_Tx_Serial  <= '1';
        r_Tx_Bit_Ctr <= 0;
        r_Tx_Clk_Ctr <= 0;
      else
        -- Debugging Level Check: Loops while button is pressed
        if i_Tx_Trigger = '1' and r_Tx_Active = '0' then
          r_Tx_Active  <= '1';
          r_Tx_Bit_Ctr <= 0;
          r_Tx_Clk_Ctr <= 0;
          
          -- Load the exact hex array in direct, readable order
          r_Tx_Packet(0) <= x"AA"; -- Header
          r_Tx_Packet(1) <= x"00";
          r_Tx_Packet(2) <= x"03";
          r_Tx_Packet(3) <= x"01";
          r_Tx_Packet(4) <= x"00";
          r_Tx_Packet(5) <= x"01";
          r_Tx_Packet(6) <= x"00";
          r_Tx_Packet(7) <= x"00";
          r_Tx_Packet(8) <= x"FF";
          r_Tx_Packet(9) <= x"56";
        
        elsif r_Tx_Active = '1' then
          -- Calculate exactly which byte and bit we are currently transmitting
          v_Byte_Idx := r_Tx_Bit_Ctr / 10;
          v_Bit_Idx  := r_Tx_Bit_Ctr rem 10;
          
          -- Standard UART Framing Generation
          if v_Bit_Idx = 0 then
            w_Tx_Serial <= '0'; -- Start Bit
          elsif v_Bit_Idx = 9 then
            w_Tx_Serial <= '1'; -- Stop Bit
          else
            -- Send Data Bits LSB-First (v_Bit_Idx 1 maps to Data Bit 0)
            w_Tx_Serial <= r_Tx_Packet(v_Byte_Idx)(v_Bit_Idx - 1);
          end if;
          
          -- 10 Clocks Per Bit Timing (10 Mbps)
          if r_Tx_Clk_Ctr = 9 then
            r_Tx_Clk_Ctr <= 0;
            if r_Tx_Bit_Ctr = 99 then
              r_Tx_Active <= '0';
            else
              r_Tx_Bit_Ctr <= r_Tx_Bit_Ctr + 1;
            end if;
          else
            r_Tx_Clk_Ctr <= r_Tx_Clk_Ctr + 1;
          end if;
        else
          w_Tx_Serial <= '1'; -- Idle high state
        end if;
      end if;
    end if;
  end process p_Internal_TX;

  -- ==========================================================================
  -- Receiver Wrapper Instantiation
  -- ==========================================================================
  UUT_Receiver : UART_10Byte_XOR_80Bit
    generic map (
